FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /opt/dbt

COPY requirements-validation.txt .
RUN pip install --no-cache-dir -r requirements-validation.txt

COPY dbt_project.yml profiles.yml ./
COPY models ./models
COPY tests ./tests
COPY tools/validate_and_rollback.py ./validate_and_rollback.py

ENTRYPOINT ["python", "/opt/dbt/validate_and_rollback.py"]
