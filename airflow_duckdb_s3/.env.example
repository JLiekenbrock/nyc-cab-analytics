AIRFLOW_IMAGE=airflow-duckdb-s3-airflow:2.10.4
AIRFLOW_PORT=8082
PIPELINE_IMAGE=registry.example.com/data/airflow-duckdb-s3:0.1.0
OPENSHIFT_NAMESPACE=data-jobs
OPENSHIFT_SERVICE_ACCOUNT=duckdb-s3-runner
OPENSHIFT_S3_SECRET=duckdb-s3-credentials
KUBECONFIG=C:/Users/you/.kube/config

AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=eu-central-1
AWS_ENDPOINT_URL=
AWS_SESSION_TOKEN=
S3_USE_SSL=true
S3_URL_STYLE=vhost
DBT_INPUT_URI_TEMPLATE=s3://my-bucket/raw/mandant={mandant}/stichtag=*/**/*.parquet
DBT_OUTPUT_URI_TEMPLATE=s3://my-bucket/curated/mandant={mandant}/report_{run_id}.parquet
